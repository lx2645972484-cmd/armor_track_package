<?xml version="1.0"?>
<robot name="turret_with_camera_imu">
  <material name="gray">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.1 0.1 0.8 0.9"/>
  </material>
  <material name="dark_gray">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>
  <material name="red">
    <color rgba="0.8 0.1 0.1 1.0"/>
  </material>
  <material name="imu_color">
    <color rgba="0.0 0.8 0.0 1.0"/>
  </material>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.15 0.15 0.03"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="gray"/>
    </visual>
  </link>

  <link name="turret_base_link">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.04"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="yaw_joint" type="continuous">
    <parent link="base_link"/>
    <child link="turret_base_link"/>
    <origin xyz="0.0 0.0 0.02" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="turret_top_link">
    <visual>
      <geometry>
        <box size="0.08 0.12 0.05"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="dark_gray"/>
    </visual>
  </link>

  <joint name="pitch_joint" type="continuous">
    <parent link="turret_base_link"/>
    <child link="turret_top_link"/>
    <origin xyz="0.03 0.0 0.015" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.04 0.04 0.03"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <visual>
      <geometry>
        <sphere radius="0.008"/>
      </geometry>
      <origin xyz="0.022 0 0" rpy="0 0 0"/>
      <material name="red"/>
    </visual>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="turret_top_link"/>
    <child link="camera_link"/>
    <origin xyz="0.05 0.0 0.0" rpy="0 0 0"/>
  </joint>

  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.02"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="imu_color"/>
    </visual>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.03" rpy="0 0 0"/>
  </joint>

</robot>